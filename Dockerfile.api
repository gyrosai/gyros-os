# API FastAPI — servidor HTTP para webhooks e administração.
FROM python:3.12-slim

WORKDIR /app

# Instala uv para gerenciar dependências
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copia apenas arquivos de dependência primeiro (cache de layers)
COPY pyproject.toml uv.lock ./

# Instala dependências sem dev
RUN uv pip install --system --no-dev .

# Copia código fonte e migrações
COPY src/ src/
COPY db/ db/

# Instala o pacote
RUN uv pip install --system --no-deps .

EXPOSE 8000

CMD ["uvicorn", "whatsapp_langchain.server.main:app", "--host", "0.0.0.0", "--port", "8000"]
