# Worker — processador de mensagens da fila.
FROM python:3.12-slim

WORKDIR /app

# Instala uv para gerenciar dependências
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copia apenas arquivos de dependência primeiro (cache de layers)
COPY pyproject.toml uv.lock ./

# Copia código fonte e migrações
COPY src/ src/
COPY db/ db/

# Instala o pacote e dependências de runtime
RUN uv pip install --system .

CMD ["python", "-m", "whatsapp_langchain.worker.main"]
